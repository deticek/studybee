<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/textView"
        android:layout_width="368dp"
        android:layout_height="115dp"
        android:text="Welcom to StudyBee"
        android:textAlignment="center"
        android:textColor="@color/besedilosvetlo"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.099" />

    <EditText
        android:id="@+id/getnametext"
        android:layout_width="321dp"
        android:layout_height="57dp"
        android:ems="10"
        android:inputType="text"
        android:text=""
        android:textStyle="bold"
        android:textColor="@color/besedilosvetlo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="304dp"
        android:layout_height="49dp"
        android:layout_marginBottom="20dp"
        android:text="How can we call you?"
        android:textAlignment="center"
        android:textColor="@color/besedilosvetlo"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/getnametext"
        app:layout_constraintEnd_toEndOf="@+id/getnametext"
        app:layout_constraintStart_toStartOf="@+id/getnametext" />

    <Button
        android:id="@+id/submit"
        android:layout_width="151dp"
        android:layout_height="84dp"
        android:layout_marginTop="36dp"
        android:onClick="goBack"
        android:text="Submit"
        android:textColor="@color/besedilosvetlo"
        android:background="@drawable/buttonborder"
        android:textSize="26dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="@+id/getnametext"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="@+id/getnametext"
        app:layout_constraintTop_toBottomOf="@+id/getnametext" />
</androidx.constraintlayout.widget.ConstraintLayout>